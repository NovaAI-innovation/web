# Strict context minimization

# Dependencies and build output
node_modules/
.next/
out/
build/
coverage/
dist/
*.tsbuildinfo
next-env.d.ts

# Hidden files/directories (context pollution)
.*
**/.*/

# Keep git internals and this rule file usable
!.git/
!.gitignore

# Environment files
.env
.env.*
*.env
*.env.*
**/.env
**/.env.*
**/*.env
**/*.env.*

# Cache/temp directories
.cache/
cache/
**/.cache/
**/cache/
tmp/
temp/
**/tmp/
**/temp/


# Operational/support directories
scripts/
nginx/
docs/
.data/
@.data/

# Docker-related
Dockerfile
Dockerfile.*
docker-compose.yml
docker-compose.*.yml
.dockerignore
*docker*
*Docker*
**/*docker*
**/*Docker*

# Package/lock files
package.json
package-lock.json
npm-shrinkwrap.json
yarn.lock
pnpm-lock.yaml


# Documentation/text instructions
*.md
CODEOWNERS
