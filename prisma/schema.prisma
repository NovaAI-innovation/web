generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────
// IDENTITY & ACCESS
// ─────────────────────────────────────────────

model Role {
  id   Int    @id @default(autoincrement())
  name String @unique

  users User[]
}

model User {
  id              String                 @id
  name            String
  email           String                 @unique
  phone           String?
  passwordHash    String
  legacySalt      String?
  roleId          Int
  role            Role                   @relation(fields: [roleId], references: [id])
  emailVerifiedAt DateTime?
  createdAt       DateTime               @default(now())

  notificationPrefs NotificationPreference?
  projects         Project[]
  invoices         Invoice[]
  portalMessages   PortalMessage[]
  agentMemory      PortalAgentMemory[]
}

model NotificationPreference {
  userId         String @id
  user           User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  emailMessages  Boolean @default(true)
  emailMilestones Boolean @default(true)
  emailBudget    Boolean @default(false)
  emailMarketing Boolean @default(false)
}

// ─────────────────────────────────────────────
// PROJECTS
// ─────────────────────────────────────────────

model Project {
  id             String         @id
  clientId       String
  client         User           @relation(fields: [clientId], references: [id])
  name           String
  status         String
  progress       Int            // 0-100
  budgetAllocated Float
  budgetSpent    Float
  baselineEnd    DateTime?
  currentEnd     DateTime?
  daysVariance   Int
  createdAt      DateTime       @default(now())

  milestones     Milestone[]
  activity       ProjectActivity[]
  invoices       Invoice[]
}

model Milestone {
  id       String  @id
  projectId String
  project  Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  title    String
  completed Boolean @default(false)
  dueDate  DateTime?
  weight   Float   @default(1.0)
}

model ProjectActivity {
  id       String  @id
  projectId String
  project  Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  type     String
  message  String
  createdAt DateTime @default(now())
}

// ─────────────────────────────────────────────
// INVOICES
// ─────────────────────────────────────────────

model Invoice {
  id             String            @id
  clientId       String
  projectId      String
  client         User              @relation(fields: [clientId], references: [id])
  project        Project           @relation(fields: [projectId], references: [id])
  number         String            @unique
  status         String
  issuedDate     DateTime
  dueDate        DateTime
  paidDate       DateTime?
  subtotal       Float
  tax            Float
  total          Float
  isFinalInvoice Boolean           @default(false)

  lineItems      InvoiceLineItem[]
}

model InvoiceLineItem {
  id          Int      @id @default(autoincrement())
  invoiceId   String
  invoice     Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  description String
  quantity    Float
  unitPrice   Float
  total       Float
}

// ─────────────────────────────────────────────
// CLIENT PORTAL
// ─────────────────────────────────────────────

model PortalMessage {
  id                   String  @id
  clientId             String
  client               User    @relation(fields: [clientId], references: [id])
  author               String
  body                 String
  reasoning            String?
  readByClient         Boolean @default(false)
  attachmentFilename   String?
  attachmentOriginalName String?
  attachmentSize       Int?
  createdAt            DateTime @default(now())
}

model PortalAgentMemory {
  id             String   @id
  clientId       String
  client         User     @relation(fields: [clientId], references: [id])
  query          String
  responseSummary String
  artifactRefs   String[]
  createdAt      DateTime @default(now())
}

// ─────────────────────────────────────────────
// LEADS
// ─────────────────────────────────────────────

model Lead {
  id          String   @id
  name        String
  email       String
  phone       String?
  projectType String
  timeline    String
  budget      String
  source      String
  message     String?
  createdAt   DateTime @default(now())
}
